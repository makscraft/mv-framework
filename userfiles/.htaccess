# Denies directory listing
Options -Indexes

# Allowes the http access to files
RewriteEngine off

# Denies execution of any kind of scripts
<Files ~ "\.(php[2-5]?|cgi|pl|fcgi|fpl|phtml|shtml|asp|jsp)$">
    Require all denied
</Files>

# Protection against MIME type spoofing (XSS attacks)
<IfModule mod_headers_c>
    Header set X-Content-Type-Options "nosniff"
</IfModule>